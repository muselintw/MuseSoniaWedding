{
  "type": "carousel",
  "contents": [
    {
      "type": "bubble",
      "size": "kilo",
      "header": {
        "type": "box",
        "layout": "vertical",
        "contents": [
          {
            "type": "text",
            "text": "🚗 開車前往",
            "color": "#FFFFFF",
            "weight": "bold",
            "size": "lg",
            "align": "center"
          }
        ],
        "paddingAll": "16px"
      },
      "hero": {
        "type": "image",
        "url": "https://i.meee.com.tw/mffJgz6.jpg",
        "size": "full",
        "aspectRatio": "20:13",
        "aspectMode": "cover"
      },
      "body": {
        "type": "box",
        "layout": "vertical",
        "contents": [
          {
            "type": "text",
            "text": "莊園周邊停車位較有限，建議停至：",
            "wrap": true,
            "size": "xs",
            "color": "#555555"
          },
          {
            "type": "text",
            "text": "中山國中停車場",
            "size": "md",
            "weight": "bold",
            "margin": "lg",
            "align": "center",
            "color": "#333333"
          },
          {
            "type": "text",
            "text": "台北市松山區民權東路三段\n140 巷 15 號",
            "wrap": true,
            "size": "xs",
            "color": "#888888",
            "margin": "sm",
            "align": "center"
          },
          {
            "type": "text",
            "text": "🚶 停妥後步行約 6 分鐘即可抵達",
            "wrap": true,
            "size": "xs",
            "color": "#95A58D",
            "margin": "lg"
          }
        ],
        "paddingAll": "16px",
        "spacing": "none"
      },
      "footer": {
        "type": "box",
        "layout": "vertical",
        "contents": [
          {
            "type": "button",
            "action": {
              "type": "uri",
              "label": "🅿️ 停車場導航",
              "uri": "https://maps.app.goo.gl/6798CnvXKfPxAoxFA"
            },
            "style": "primary",
            "color": "#9BAED4",
            "height": "sm"
          }
        ],
        "paddingAll": "12px"
      },
      "styles": {
        "header": { "backgroundColor": "#9BAED4" },
        "body": { "backgroundColor": "#F7F8F8" },
        "footer": { "backgroundColor": "#F7F8F8" }
      }
    },
    {
      "type": "bubble",
      "size": "kilo",
      "header": {
        "type": "box",
        "layout": "vertical",
        "contents": [
          {
            "type": "text",
            "text": "🚇 大眾運輸",
            "color": "#FFFFFF",
            "weight": "bold",
            "size": "lg",
            "align": "center"
          }
        ],
        "paddingAll": "16px"
      },
      "hero": {
        "type": "image",
        "url": "https://i.meee.com.tw/wbHKgPA.jpg",
        "size": "full",
        "aspectRatio": "20:13",
        "aspectMode": "cover"
      },
      "body": {
        "type": "box",
        "layout": "vertical",
        "contents": [
          {
            "type": "text",
            "text": "🚈 捷運",
            "size": "sm",
            "weight": "bold",
            "color": "#333333"
          },
          {
            "type": "text",
            "text": "「松山機場站」2 號或 3 號出口\n或「中山國中站」",
            "wrap": true,
            "size": "xs",
            "color": "#555555",
            "margin": "sm"
          },
          {
            "type": "text",
            "text": "出站步行約 8–10 分鐘",
            "size": "xs",
            "color": "#888888",
            "margin": "xs"
          },
          {
            "type": "separator",
            "margin": "lg",
            "color": "#DADEDF"
          },
          {
            "type": "text",
            "text": "🚌 公車",
            "size": "sm",
            "weight": "bold",
            "margin": "lg",
            "color": "#333333"
          },
          {
            "type": "text",
            "text": "搭至「民生敦化站」或「長庚醫院站」，下車後步行即可到達。",
            "wrap": true,
            "size": "xs",
            "color": "#555555",
            "margin": "sm"
          }
        ],
        "paddingAll": "16px",
        "spacing": "none"
      },
      "styles": {
        "header": { "backgroundColor": "#C0CFB2" },
        "body": { "backgroundColor": "#F7F8F8" }
      }
    }
